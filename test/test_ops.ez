start() begin
num a = 10
num b = 22
num c
c = a + b
show("ADD") 
show(c) 
c = b - a
show("SUB") 
show(c) 
c = a * b
show("MUL") 
show(c) 
c = b / a
show("DIV") 
show(c) 
check(a equals 10) begin
show("EQUALS TRUE") 
end
check(a differs b) begin
show("DIFFERS TRUE") 
end
num x = 0
x = 5
show("ASSIGN") 
show(x) 
send 0
end
